{
  "name": "@logbrew/react-native",
  "version": "0.1.0",
  "description": "React Native screen, error, trace, action, and network timeline helpers for LogBrew.",
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "react-native": "./index.native.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "react-native": "./index.native.js",
      "import": {
        "types": "./index.d.ts",
        "default": "./index.js"
      },
      "require": {
        "types": "./index.d.cts",
        "default": "./index.cjs"
      },
      "default": "./index.js"
    }
  },
  "files": [
    "index.cjs",
    "index.js",
    "index.native.js",
    "index.d.ts",
    "index.d.cts",
    "README.md",
    "examples"
  ],
  "keywords": [
    "logbrew",
    "react-native",
    "mobile",
    "observability",
    "logs",
    "traces",
    "events"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LogBrewCo/sdk.git"
  },
  "peerDependencies": {
    "@logbrew/sdk": "^0.1.0",
    "react": ">=18",
    "react-native": ">=0.72"
  },
  "scripts": {
    "test": "node --check index.js && node --check index.cjs && node --check index.native.js && node --check examples/index.mjs && node --check examples/navigation-resource-spans.mjs && node --check examples/readme-example.mjs && node --check examples/real-user-smoke.mjs && node --check examples/trace-correlation.mjs"
  }
}
