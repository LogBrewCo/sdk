{
  "name": "@logbrew/sdk",
  "version": "0.1.3",
  "description": "Public LogBrew JavaScript SDK for building, validating, and flushing event batches.",
  "type": "module",
  "main": "./index.cjs",
  "types": "./index.d.ts",
  "bin": {
    "logbrew-release-artifacts": "./release-artifacts.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.ts",
        "default": "./index.js"
      },
      "require": {
        "types": "./index.d.cts",
        "default": "./index.cjs"
      },
      "default": "./index.js"
    }
  },
  "files": [
    "index.cjs",
    "index.js",
    "index.d.ts",
    "index.d.cts",
    "release-artifacts.js",
    "release-artifacts-symbolication.js",
    "README.md",
    "examples"
  ],
  "keywords": [
    "logbrew",
    "observability",
    "logs",
    "traces",
    "events"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LogBrewCo/sdk.git"
  },
  "scripts": {
    "test": "node --test",
    "smoke": "node ./smoke.js"
  }
}
